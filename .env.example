# ARC Environment Configuration
# Copy this file to .env and fill in the values.
# All variables use the ARC_ prefix.

# ── Telegram Bot ──────────────────────────────────────────────
# Get a token from @BotFather on Telegram. Leave empty to run
# without Telegram (admin chat at http://localhost:8080/chat).
ARC_TELEGRAM_BOT_TOKEN=

# ── Ollama ────────────────────────────────────────────────────
ARC_OLLAMA_HOST=http://localhost:11434
ARC_OLLAMA_MODEL=minimax-m2.5
ARC_OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Database ──────────────────────────────────────────────────
ARC_SQLITE_DB_PATH=data/arc.db
ARC_CHROMADB_PATH=data/chromadb

# ── Context Window ────────────────────────────────────────────
ARC_CONTEXT_WINDOW_TOKENS=8192
ARC_COMPACTION_THRESHOLD=0.5

# ── Heartbeat ─────────────────────────────────────────────────
ARC_HEARTBEAT_INTERVAL_MINUTES=15

# ── Personality & Templates ───────────────────────────────────
ARC_SOUL_PATH=data/soul.md
ARC_HEARTBEAT_PATH=data/heartbeat.md

# ── Admin Dashboard ───────────────────────────────────────────
ARC_ADMIN_HOST=0.0.0.0
ARC_ADMIN_PORT=8080

# ── Agent Behaviour ───────────────────────────────────────────
ARC_MAX_AGENT_ITERATIONS=10

# ── MCP Servers ───────────────────────────────────────────────
# MCP tool servers are configured in data/mcp_servers.json
# (not as environment variables). See README.md for details.
