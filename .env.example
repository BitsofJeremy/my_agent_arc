# ARC Environment Configuration
# Copy this file to .env and fill in the values.
# All variables use the ARC_ prefix.

# Telegram Bot
ARC_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Ollama
ARC_OLLAMA_HOST=http://localhost:11434
ARC_OLLAMA_MODEL=llama3.1:8b
ARC_OLLAMA_EMBED_MODEL=nomic-embed-text

# Database
ARC_SQLITE_DB_PATH=data/arc.db
ARC_CHROMADB_PATH=data/chromadb

# Context Window
ARC_CONTEXT_WINDOW_TOKENS=8192
ARC_COMPACTION_THRESHOLD=0.5

# Heartbeat
ARC_HEARTBEAT_INTERVAL_MINUTES=15

# Admin
ARC_ADMIN_HOST=0.0.0.0
ARC_ADMIN_PORT=8080
