{
  "servers": {
    "test": {
      "command": "uv",
      "args": [
        "run",
        "tools/test_server.py"
      ]
    },
    "dice": {
      "command": "uv",
      "args": [
        "run",
        "tools/dice_server.py"
      ]
    },
    "docker": {
      "command": "uv",
